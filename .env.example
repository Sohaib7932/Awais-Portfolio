# ---------------------------------------------------------------
# Contact form email delivery
# ---------------------------------------------------------------
# Copy this file to `.env.local` and fill in the key below.
# `.env.local` is git-ignored, so your key stays private.
#
# How to get RESEND_API_KEY (free, ~2 minutes):
#   1. Sign up at https://resend.com  — use awais.m4325@gmail.com
#   2. Verify your email address
#   3. Go to https://resend.com/api-keys and click "Create API Key"
#   4. Copy the key (it starts with re_) and paste it below
#   5. Restart the dev server:  npm run dev
#
# Note: without your own domain, Resend only delivers to the address
# you signed up with — which is exactly what we want here.

RESEND_API_KEY=

# Optional overrides — the defaults are already correct.
# CONTACT_TO_EMAIL=awais.m4325@gmail.com
# CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
